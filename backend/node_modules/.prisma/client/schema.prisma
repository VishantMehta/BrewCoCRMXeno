generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  phone         String?
  city          String?
  total_spend   Float     @default(0.0)
  order_count   Int       @default(0)
  last_order_at DateTime?
  tags          String? // stored as JSON string or comma-separated
  created_at    DateTime  @default(now())

  orders            Order[]
  communicationLogs CommunicationLog[]
}

model Order {
  id          Int      @id @default(autoincrement())
  customer_id Int
  amount      Float
  items_json  String // JSON string of items bought
  channel     String // e.g., "Web", "App", "In-store"
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])
}

model Segment {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  rules_json    String // JSON representing the filter rules
  created_by_ai Boolean  @default(false)
  created_at    DateTime @default(now())

  campaigns Campaign[]
}

model Campaign {
  id               Int       @id @default(autoincrement())
  name             String
  segment_id       Int
  message_template String
  channel          String // e.g., "WhatsApp", "Email", "SMS"
  status           String    @default("draft") // draft, launched, completed
  created_at       DateTime  @default(now())
  launched_at      DateTime?

  segment           Segment            @relation(fields: [segment_id], references: [id])
  communicationLogs CommunicationLog[]
}

model CommunicationLog {
  id           Int       @id @default(autoincrement())
  campaign_id  Int
  customer_id  Int
  message      String
  channel      String
  status       String    @default("pending") // pending, sent, delivered, failed, opened, clicked
  sent_at      DateTime?
  delivered_at DateTime?
  opened_at    DateTime?
  clicked_at   DateTime?

  campaign Campaign @relation(fields: [campaign_id], references: [id])
  customer Customer @relation(fields: [customer_id], references: [id])
}
